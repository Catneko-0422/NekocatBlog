# Mizuki 博客環境變量配置示例
# 複製此文件爲 .env 並根據需要填寫實際值

# ============================================
# 內容倉庫配置 (代碼內容分離)
# 項目地址:https://github.com/matsuzaka-yuki/Mizuki-Content
# ============================================

# 是否啓用內容分離功能 (true/false)
# true: 啓用內容分離,從獨立倉庫同步內容
# false: 禁用內容分離,使用本地內容 (默認模式)
# 注意: 如果不使用內容分離功能,可以註釋掉或設置爲 false
ENABLE_CONTENT_SYNC=false

# 內容倉庫的 Git URL (僅在 ENABLE_CONTENT_SYNC=true 時需要)
# 支持 HTTPS 和 SSH 兩種方式:
# HTTPS: https://github.com/your-username/Mizuki-Content.git
# SSH: git@github.com:your-username/Mizuki-Content.git
CONTENT_REPO_URL=https://github.com/your-username/Mizuki-Content.git

# 內容目錄路徑 (相對於項目根目錄)
# 默認: ./content 一般無需改動
CONTENT_DIR=./content

# ============================================
# 自動構建觸發配置 (內容倉庫更新時)
# ============================================

# 問題: 內容倉庫更新不會自動觸發代碼倉庫的部署
# 解決: 配置自動觸發機制,推薦使用 Repository Dispatch
# 詳見: docs/AUTO_BUILD_TRIGGER.md (5 步快速配置)

# ============================================
# IndexNow SEO 配置
# ============================================

# IndexNow API 密鑰，用於向搜索引擎提交 URL 更新
INDEXNOW_KEY=asdf1213456
# 網站主機地址
INDEXNOW_HOST=your.example.com

# ============================================
# B站相關配置 (用於獲取觀看進度)
# ============================================

# SESSDATA 的獲取：
# 1. 登錄 bilibili 賬號
# 2. 打開瀏覽器開發者工具（F12 或 Ctrl+Shift+I）
# 3. 找到“應用程序”(app)一欄
# 4. 在請求頭中查找 cookie 字段
# 5. 從 cookie 中提取 sessdata 值

# 環境變量名：BILI_SESSDATA     key值：sessdata
BILI_SESSDATA=your_bilibili_sessdata
