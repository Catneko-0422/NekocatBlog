---
/**
 * CardTOC - 卡片式目錄組件
 * 使用 WidgetLayout (豎線+標題封裝)
 * 複用 TOCManager 邏輯
 */

import "@/styles/toc.css";

import type { MarkdownHeading } from "astro";
import { siteConfig } from "@/config";

import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import WidgetLayout from "../common/WidgetLayout.astro";

interface Props {
	class?: string;
	style?: string;
	headings?: MarkdownHeading[];
}

const { class: className, style } = Astro.props;
const useJapaneseBadge = siteConfig.toc.useJapaneseBadge;
---

<WidgetLayout
	name={i18n(I18nKey.tableOfContents)}
	id="card-toc"
	class={"group " + (className || "")}
	style={style}
>
	<div data-card-toc-root data-japanese-badge={String(useJapaneseBadge)}>
		<div class="toc-scroll-container">
			<div class="toc-content" data-card-toc-content></div>
		</div>
	</div>
</WidgetLayout>

<style>
	.toc-scroll-container {
		max-height: 50vh;
		overflow-y: auto;
		scrollbar-width: none;
		-ms-overflow-style: none;
	}

	.toc-scroll-container::-webkit-scrollbar {
		display: none;
		width: 0;
		height: 0;
	}
</style>

<script>
	import { TOCManager } from "@/utils/tocManager";

	const cardTocManagers = new WeakMap();

	/**
	 * 爲單個 card-toc 實例初始化目錄。
	 * 目錄綁定當前組件自己的內容容器，避免左側多斷點並存時命中隱藏實例。
	 */
	function initCardTOC(root: Element) {
		if (!(root instanceof HTMLElement)) {
			return;
		}

		const tocContent = root.querySelector("[data-card-toc-content]");
		if (!(tocContent instanceof HTMLElement)) {
			return;
		}

		try {
			const existingManager = cardTocManagers.get(root);
			if (
				existingManager &&
				typeof existingManager.cleanup === "function"
			) {
				existingManager.cleanup();
			}

			const useJapaneseBadge = root.dataset.japaneseBadge === "true";

			const manager = new TOCManager({
				contentElement: tocContent,
				maxLevel: 3,
				useJapaneseBadge,
				scrollOffset: 80,
			});

			cardTocManagers.set(root, manager);
			manager.init();
		} catch (error) {
			if (typeof reportError === "function" && error instanceof Error) {
				reportError(error);
			}
		}
	}

	/**
	 * 頁面內可能同時存在多個 card-toc 實例。
	 * 統一批量初始化，確保可見和隱藏實例都各自綁定正確容器。
	 */
	function initAllCardTOCs() {
		document.querySelectorAll("[data-card-toc-root]").forEach((root) => {
			initCardTOC(root);
		});
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initAllCardTOCs);
	} else {
		initAllCardTOCs();
	}

	document.addEventListener("swup:contentReplaced", () => {
		setTimeout(initAllCardTOCs, 100);
	});

	document.addEventListener("astro:page-load", () => {
		setTimeout(initAllCardTOCs, 100);
	});

	document.addEventListener("astro:after-swap", () => {
		setTimeout(initAllCardTOCs, 100);
	});

	window.addEventListener("popstate", () => {
		setTimeout(initAllCardTOCs, 200);
	});

	window.addEventListener("hashchange", () => {
		if (!window.tocInternalNavigation) {
			setTimeout(initAllCardTOCs, 100);
		}
		window.tocInternalNavigation = false;
	});

	document.addEventListener("password:decrypted", () => {
		setTimeout(initAllCardTOCs, 200);
	});
</script>
